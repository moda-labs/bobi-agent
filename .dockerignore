# Keep the build context small and the wheel reproducible. The sdist build
# needs: bobi/, event-server/, agents/, README.md, CHANGELOG.md
# (see pyproject [tool.hatch.build.targets.sdist]). Everything else is noise.

.git
.github
.venv
venv
.claude
.bobi
workspace

# Python build artifacts / caches
**/__pycache__
**/*.pyc
**/*.pyo
.pytest_cache
.mypy_cache
.ruff_cache
dist
# …except the rendered team-deps hook (C24): build-team-images.sh writes it under
# dist/ and the Dockerfile COPYs it via the TEAM_DEPS build-arg, so it MUST be in
# the build context. Re-include just that subtree.
!dist/team-deps
!dist/team-deps/**
# …and the prebuilt wheel (BOBI_BUILD=wheel): the release pipeline stages the
# artifact into dist/ and builder-wheel COPYs it. Present only in wheel-mode builds.
!dist/*.whl
build
*.egg-info

# Node build artifacts (event-server source is force-included; its deps are not)
event-server/node_modules
event-server/dist

# Tests and docs aren't needed to build or run the image
tests
docs

# Local scratch / handoff files
HANDOFF-*.md
RELEASE-CLEANUP-STATUS.md
*.log
