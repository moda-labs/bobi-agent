# INACTIVE until C24 (#368). eng-team has a `requires: gstack/codex` gate that
# blocks agent dispatch in the bare image, so deploying it now would provision a
# real-but-non-functional instance. Rename to eng-team.yaml to activate once the
# team-flavored image (C24) ships.
# deployments/eng-team.yaml — moda's internal engineering-org instance.
#
# The deployment NAME is this filename ("eng-team"); the app is "<fleet>-eng-team"
# (fleet from defaults.yaml = moda → app "moda-eng-team"). Adding/editing this
# file is what deploys — `modastack deploy eng-team`, or the GitOps Action on a
# push to main (.github/workflows/gitops-teams.yml reconciles deployments/*.yaml).

# Delivery: a LOCAL package (agents/eng-team) → ssh-push. CI checks out this repo,
# builds the package into a tarball, and pushes it onto the instance over fly ssh
# — no published-tarball infrastructure needed. Swap to `team-url: <url>` to
# pull a published tarball at first boot instead.
team: eng-team

# Secrets: the GitHub Environment that holds this instance's KEY=VALUE blob. The
# Action binds the matrix cell to it and passes the values to `modastack deploy`
# as an --env-file. (Convention: the Environment is named after the deployment.)
# For self-service, drop this and use `secrets: { env-file: ./eng-team.env }`.
secrets:
  env: eng-team
