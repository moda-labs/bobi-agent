# Manual example deployment: a Codex-brained agent on a dedicated Fly app (#485).
#
# This file is intentionally `.yaml.example`, not `.yaml`, so release
# reconciliation does not deploy it by default. The old active `codex-test`
# deployment mixed two independent validation concerns:
#
# 1. Codex as the agent brain.
# 2. Local `team:` delivery over Fly SSH (`ssh-push`).
#
# Keep those as separate canaries/tests. This example remains useful for manual
# Codex runtime experiments once a Slack app, login channel, and subscription
# auth ceremony are intentionally wired.
#
# App name = <fleet>-<name> = ci-codex-test (fleet from deployments/defaults.yaml).
#
# ChatGPT-subscription auth: NO OPENAI_API_KEY in secrets — first boot runs the
# codex device-auth login bootstrap (posts the URL + code to login_channel; you
# authorize, and auth.json lands on the volume). Set login_channel before
# deploying. Use a private "#channel", "@user" for a bot DM in this Slack
# workspace, or a raw Slack channel ID if needed.
team: codex-test
auth: subscription
login_channel: ""        # e.g. "#login-private" or "@zachkozick"
memory: 1gb
cpus: 1
volume_size: 3
