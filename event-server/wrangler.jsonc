{
	"name": "modastack-events",
	"main": "src/index.ts",
	"compatibility_date": "2025-05-26",
	"observability": {
		"enabled": true
	},
	// Required Cloudflare Worker secret:
	//   wrangler secret put INTERNAL_DO_SECRET
	// Do not store this value in wrangler.jsonc, .env, Fly, Bubble, or agent-team env.
	"kv_namespaces": [
		{
			"binding": "EVENTS",
			"id": "e84e897a6ee0421b891494f02ded6562"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "DEPLOYMENT_SESSION",
				"class_name": "DeploymentSession"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["DeploymentSession"]
		}
	]
}
