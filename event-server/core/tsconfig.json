{
	// Dist build for the publishable tarball only (scripts/pack.mjs). The
	// repo consumes this package straight from src/ via the workspace
	// exports map; nothing in-repo depends on dist/.
	"compilerOptions": {
		"target": "es2022",
		// No runtime pin: core is runtime-agnostic (Node local server +
		// Cloudflare worker). DOM supplies the web-standard globals it uses
		// (fetch, crypto.subtle, TextEncoder).
		"lib": ["es2024", "dom"],
		"module": "es2022",
		"moduleResolution": "bundler",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"]
}
